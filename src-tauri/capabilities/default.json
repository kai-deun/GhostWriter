{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "local-metadata-editor:default",
    "local-metadata-editor:allow-get-metadata",
    "local-metadata-editor:allow-scrub-metadata"
  ]
}